{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenMIA Docs",
  "colors": {
    "primary": "#2563EB",
    "light": "#38BDF8",
    "dark": "#1E40AF"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Start here",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "OpenMIA App",
        "pages": [
          "app/observation",
          "app/observation/projects",
          "app/observation/integrations",
          "app/observation/ingestion",
          "app/observation/traces",
          "app/observation/raw-payloads-import-jobs",
          "app/observation/feedback-audit",
          "app/observation/security-permissions",
          "app/observation/troubleshooting"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "OpenMIA App",
          "href": "https://app.openmia.ai",
          "icon": "grid-2"
        },
        {
          "anchor": "Auth dashboard",
          "href": "https://auth.openmia.ai/dashboard",
          "icon": "user-gear"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/light.svg",
    "dark": "/images/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@openmia.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.openmia.ai"
    }
  },
  "contextual": {
    "options": [
      "copy"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/openmia-ai"
    }
  }
}
